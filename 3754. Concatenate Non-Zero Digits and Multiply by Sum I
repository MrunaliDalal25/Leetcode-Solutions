class Solution {
    public int concatenateNonZeroDigitsAndMultiplyBySum(int n) {
        if (n == 0) return 0;

        int[] digits = new int[10]; // n <= 10^9 => at most 10 digits
        int count = 0;

        while (n > 0) {
            digits[count++] = n % 10;
            n /= 10;
        }

        int x = 0;
        int sum = 0;

        for (int i = count - 1; i >= 0; i--) {
            if (digits[i] != 0) {
                x = x * 10 + digits[i];
                sum += digits[i];
            }
        }

        return x * sum;
    }
}
