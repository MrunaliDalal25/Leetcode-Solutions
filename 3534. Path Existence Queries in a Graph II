import java.util.*;

class Solution {
    public int[] pathExistenceQueries(int n, int[] nums, int maxDiff, int[][] queries) {
        int[] ans = new int[queries.length];

        int[][] arr = new int[n][2];
        for (int i = 0; i < n; i++) {
            arr[i][0] = nums[i];
            arr[i][1] = i;
        }

        Arrays.sort(arr, (a, b) -> Integer.compare(a[0], b[0]));

        int[] sorted = new int[n];
        int[] pos = new int[n];
        for (int i = 0; i < n; i++) {
            sorted[i] = arr[i][0];
            pos[arr[i][1]] = i;
        }

        int LOG = 1;
        while ((1 << LOG) <= n) LOG++;

        int[][] jump = new int[n][LOG];

        int r = 0;
        for (int l = 0; l < n; l++) {
            while (r + 1 < n && sorted[r + 1] - sorted[l] <= maxDiff) {
                r++;
            }
            jump[l][0] = r;
        }

        for (int j = 1; j < LOG; j++) {
            for (int i = 0; i < n; i++) {
                jump[i][j] = jump[jump[i][j - 1]][j - 1];
            }
        }

        for (int i = 0; i < queries.length; i++) {
            int u = pos[queries[i][0]];
            int v = pos[queries[i][1]];

            int start = Math.min(u, v);
            int end = Math.max(u, v);

            int res = minJumps(jump, start, end, LOG - 1);
            ans[i] = (res == Integer.MAX_VALUE) ? -1 : res;
        }

        return ans;
    }

    private int minJumps(int[][] jump, int start, int end, int level) {
        if (start == end)
            return 0;

        if (jump[start][0] >= end)
            return 1;

        if (jump[start][level] < end)
            return Integer.MAX_VALUE;

        int j = level;
        while (j >= 0 && jump[start][j] >= end)
            j--;

        return (1 << j) + minJumps(jump, jump[start][j], end, j);
    }
}
